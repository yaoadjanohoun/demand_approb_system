# Copier ce fichier en .env (`cp .env.example .env`) et remplir les valeurs.
# .env n'est jamais versionné (voir .gitignore) : les vraies valeurs ne
# doivent apparaître nulle part dans le dépôt Git.

# Obligatoire. Générer une valeur unique et secrète, par exemple :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Optionnel (par défaut : True en local, à mettre à False en production).
DJANGO_DEBUG=True

# Optionnel. Liste séparée par des virgules des noms d'hôte autorisés à
# servir l'application (obligatoire dès que DJANGO_DEBUG=False).
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Optionnel. Adresse affichée comme expéditeur pour les emails envoyés
# avant qu'une configuration SMTP soit active dans l'admin (Configuration
# email) — la config SMTP réelle (Gmail, Exchange, etc.) ne se met PAS ici,
# elle se saisit dans l'admin, voir approvals/models.py:EmailSettings.
DEFAULT_FROM_EMAIL=noreply@example.local

# --- Active Directory (optionnel, désactivé si AD_LDAP_SERVER_URI est vide) ---
AD_LDAP_SERVER_URI=
AD_LDAP_BIND_DN=
AD_LDAP_BIND_PASSWORD=
AD_LDAP_USER_SEARCH_BASE=

# --- SQL Server (optionnel, désactivé si SQLSERVER_HOST est vide -> SQLite) ---
SQLSERVER_HOST=
SQLSERVER_NAME=demand_approb_system
SQLSERVER_USER=
SQLSERVER_PASSWORD=
