<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuration IIS pour héberger l'application via HttpPlatformHandler
  (Les Spécifications Techniques §1.1 : "Utilisation du module HttpPlatformHandler
  (recommandé par Microsoft pour Python)").

  Déployée par la DSI, pas par l'application elle-même (§2.2 du même document) :
  - Pool d'applications : identité = compte de service (svc_django_approbation).
  - Section system.webServer/handlers déverrouillée pour autoriser HttpPlatformHandler.
  - Les valeurs ci-dessous (chemins, variables d'environnement) sont des exemples
    à adapter à l'environnement cible ; aucun secret réel ne doit être écrit ici
    (ce fichier est versionné) — utiliser le gestionnaire de configuration IIS ou
    un fichier local hors dépôt pour les valeurs sensibles en production.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>

    <httpPlatform
      processPath="..\env\Scripts\python.exe"
      arguments=".\run_production.py"
      stdoutLogEnabled="true"
      stdoutLogFile=".\logs\stdout.log"
      startupTimeLimit="60"
      startupRetryCount="3">
      <environmentVariables>
        <!-- Django -->
        <environmentVariable name="DJANGO_SETTINGS_MODULE" value="demand_approb_system_main.settings" />
        <environmentVariable name="DJANGO_DEBUG" value="False" />
        <environmentVariable name="DJANGO_ALLOWED_HOSTS" value="intranet.example.local" />
        <!-- DJANGO_SECRET_KEY : à définir par la DSI, jamais dans ce fichier versionné -->

        <!-- Active Directory (approvals/auth_backends.py) -->
        <environmentVariable name="AD_LDAP_SERVER_URI" value="ldaps://ad.example.local" />
        <environmentVariable name="AD_LDAP_BIND_DN" value="CN=svc_django_approbation,OU=ServiceAccounts,DC=example,DC=local" />
        <environmentVariable name="AD_LDAP_USER_SEARCH_BASE" value="OU=Users,DC=example,DC=local" />
        <!-- AD_LDAP_BIND_PASSWORD : à définir par la DSI -->

        <!-- SQL Server -->
        <environmentVariable name="SQLSERVER_HOST" value="sql.example.local" />
        <environmentVariable name="SQLSERVER_NAME" value="demand_approb_system" />
        <environmentVariable name="SQLSERVER_USER" value="svc_django_approbation" />
        <!-- SQLSERVER_PASSWORD : à définir par la DSI -->
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
